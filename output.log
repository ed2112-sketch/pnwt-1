      verify-2fa/page.tsx
      layout.tsx
    (dashboard)/
      layout.tsx          ← sidebar + topbar shell
      page.tsx             ← empty dashboard home
    api/
      trpc/[...trpc]/route.ts
      auth/[...nextauth]/route.ts
    layout.tsx
    page.tsx              ← redirect to /login or /dashboard
  server/
